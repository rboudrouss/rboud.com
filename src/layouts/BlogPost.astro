---
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";

interface Props {
	title: string;
	description?: string | undefined;
	pubDate: Date;
	updatedDate?: Date | undefined;
	lang?: string;
	tags?: string[];
}

const {
	title,
	description,
	pubDate,
	updatedDate,
	lang = "en",
	tags = [],
} = Astro.props;
---

<BaseLayout title={`${title} · Réda Boudrouss`} lang={lang}>
	<div class="page">
		<!-- ── NAV ── -->
		<nav class="topnav">
			<div class="container nav-inner">
				<a class="nav-name" href="/">Réda Boudrouss</a>
				<ul class="nav-links">
					<li><a href="/blog/">Blog</a></li>
					<li><a href="/">Home</a></li>
				</ul>
			</div>
		</nav>

		<main class="container article">
			<header class="article-head">
				<a class="back-link" href="/blog/">&larr; All posts</a>
				<h1>{title}</h1>
				<p class="article-meta">
					<FormattedDate date={pubDate} />
					{
						updatedDate && (
							<span class="updated">
								&middot; updated <FormattedDate date={updatedDate} />
							</span>
						)
					}
				</p>
				{
					tags.length > 0 && (
						<div class="tags">
							{tags.map((t) => <span class="tag">{t}</span>)}
						</div>
					)
				}
			</header>

			<article class="prose">
				<slot />
			</article>
		</main>

		<!-- ── FOOTER ── -->
		<footer class="footer">
			<div class="container footer-inner">
				<p><strong>Réda Boudrouss</strong> &mdash; Paris, France</p>
				<p>
					<a href="mailto:contact@rboud.com">contact@rboud.com</a>
					&nbsp;&middot;&nbsp;
					<a href="https://linkedin.com/in/rboudrouss" target="_blank">LinkedIn</a>
					&nbsp;&middot;&nbsp;
					<a href="https://github.com/rboudrouss" target="_blank">GitHub</a>
				</p>
			</div>
		</footer>
	</div>
</BaseLayout>

<style>
	/* ── Layout ── */
	.page {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}
	.container {
		width: 100%;
		max-width: var(--container);
		margin-inline: auto;
		padding-inline: 1.5rem;
	}

	/* ── Nav ── */
	.topnav {
		position: sticky;
		top: 0;
		z-index: 10;
		background: rgba(249, 248, 245, 0.88);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border);
	}
	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 3.5rem;
	}
	.nav-name {
		font-weight: 600;
		font-size: 0.95rem;
		color: var(--text);
		letter-spacing: 0.02em;
	}
	.nav-links {
		display: flex;
		gap: 1.75rem;
		list-style: none;
	}
	.nav-links a {
		color: var(--text-muted);
		font-size: 0.9rem;
		font-weight: 500;
		transition: color var(--transition);
	}
	.nav-links a:hover {
		color: var(--accent);
		opacity: 1;
	}

	/* ── Article ── */
	.article {
		flex: 1;
		padding-top: 3rem;
		padding-bottom: 5rem;
	}
	.article-head {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		margin-bottom: 2.5rem;
		padding-bottom: 1.5rem;
		border-bottom: 2px solid var(--accent-light);
	}
	.back-link {
		font-size: 0.85rem;
		color: var(--text-muted);
		font-weight: 500;
	}
	.back-link:hover {
		color: var(--accent);
		opacity: 1;
	}
	.article-head h1 {
		font-size: clamp(1.8rem, 4vw, 2.6rem);
		font-weight: 700;
		margin-top: 0.25rem;
	}
	.article-meta {
		font-size: 0.85rem;
		color: var(--text-muted);
	}
	.updated {
		font-style: italic;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 0.25rem;
	}
	.tag {
		font-size: 0.75rem;
		padding: 0.2rem 0.55rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 0.25rem;
		color: var(--text-muted);
	}

	/* ── Prose (rendered markdown) ── */
	.prose {
		line-height: 1.8;
		color: var(--text);
	}
	.prose :global(h2) {
		font-size: 1.5rem;
		font-weight: 700;
		margin-top: 2.5rem;
		margin-bottom: 0.75rem;
	}
	.prose :global(h3) {
		font-size: 1.2rem;
		font-weight: 600;
		margin-top: 2rem;
		margin-bottom: 0.5rem;
	}
	.prose :global(p) {
		margin-bottom: 1.25rem;
	}
	.prose :global(ul),
	.prose :global(ol) {
		margin-bottom: 1.25rem;
		padding-left: 1.5rem;
	}
	.prose :global(li) {
		margin-bottom: 0.4rem;
	}
	.prose :global(a) {
		color: var(--link);
		text-decoration: underline;
		text-underline-offset: 2px;
	}
	.prose :global(strong) {
		font-weight: 600;
	}
	.prose :global(blockquote) {
		border-left: 3px solid var(--accent-light);
		padding-left: 1rem;
		margin: 1.5rem 0;
		color: var(--text-muted);
		font-style: italic;
	}
	.prose :global(code) {
		font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
		font-size: 0.875em;
		background: var(--accent-subtle);
		padding: 0.15em 0.4em;
		border-radius: 0.25rem;
	}
	.prose :global(pre) {
		background: #1a1a2e;
		color: #f9f8f5;
		padding: 1rem 1.25rem;
		border-radius: 0.5rem;
		overflow-x: auto;
		margin: 1.5rem 0;
		font-size: 0.875rem;
		line-height: 1.6;
	}
	.prose :global(pre code) {
		background: none;
		padding: 0;
		font-size: inherit;
	}
	.prose :global(img) {
		border-radius: 0.5rem;
		margin: 1.5rem 0;
	}
	.prose :global(hr) {
		border: none;
		border-top: 1px solid var(--border);
		margin: 2.5rem 0;
	}
	.prose :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 1.5rem 0;
		font-size: 0.9rem;
	}
	.prose :global(th),
	.prose :global(td) {
		border: 1px solid var(--border);
		padding: 0.5rem 0.75rem;
		text-align: left;
	}
	.prose :global(th) {
		background: var(--surface);
		font-weight: 600;
	}

	/* ── Footer ── */
	.footer {
		background: var(--surface);
		border-top: 1px solid var(--border);
	}
	.footer-inner {
		padding-block: 2rem;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}
	.footer p {
		font-size: 0.875rem;
		color: var(--text-muted);
	}
	.footer a {
		color: var(--link);
	}
</style>
