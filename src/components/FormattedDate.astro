---
interface Props {
	date: Date;
	lang?: string;
}

const { date, lang = "en" } = Astro.props;

const locale = lang === "fr" ? "fr-FR" : "en-US";
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString(locale, {
			year: "numeric",
			month: "long",
			day: "numeric",
		})
	}
</time>
