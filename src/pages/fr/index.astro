---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout lang="fr">
	<div class="page">
		<!-- ── NAV ── -->
		<nav class="topnav">
			<div class="container nav-inner">
				<span class="nav-name"></span>
				<ul class="nav-links">
					<li><a href="#formation">Formation</a></li>
					<li><a href="#experiences">Expériences</a></li>
					<li>
						<a
							class="lang-switch"
							href="/"
							onclick="sessionStorage.setItem('lang-override','en')">EN</a
						>
					</li>
				</ul>
			</div>
		</nav>

		<!-- ── HERO ── -->
		<header class="hero container">
			<div class="hero-text">
				<h1>Réda Boudrouss</h1>
				<p class="hero-title">
					Étudiant M2 · Analyse statique &amp; WebAssembly
				</p>
				<p class="hero-institution">Sorbonne Université</p>
				<p class="hero-bio">
					Étudiant en Master 2 STL, je m'intéresse à l'<strong
						>analyse statique des langages dynamiques</strong
					>
					et aux possibilités offertes par <strong>WebAssembly</strong>.
					Actuellement, je travaille sur le portage de l'analyseur <strong
						><a href="https://mopsa.lip6.fr/" target="_blank">MOPSA</a></strong
					> vers WebAssembly.
				</p>
				<div class="hero-links">
					<a class="btn" href="mailto:contact@rboud.com">✉ Email</a>
					<a
						class="btn btn-ghost"
						href="https://github.com/rboudrouss"
						target="_blank">GitHub</a
					>
					<a
						class="btn btn-ghost"
						href="https://linkedin.com/in/rboudrouss"
						target="_blank">LinkedIn</a
					>
					<a class="btn btn-ghost" href="/cv.pdf" target="_blank">CV (old)</a>
				</div>
			</div>
			<div class="hero-photo">
				<img class="avatar" src="/assets/photo.jpeg" alt="Reda Boudrouss" />
			</div>
		</header>

		<main class="container main-content">
			<!-- ── FORMATION ── -->
			<section id="formation" class="section">
				<h2 class="section-title">Formation</h2>
				<div class="timeline">
					<div class="timeline-item">
						<span class="period">2024 – 2026</span>
						<div class="timeline-body">
							<strong class="tl-role"
								>Master Science et Technologie du Logiciel</strong
							>
							<span class="tl-org">Sorbonne Université</span>
							<ul class="tl-list">
								<li>
									Algorithmique avancée, conception et vérification de logiciels
									sûrs, programmation concurrente, fonctionnelle et répartie, et
									développement d'architectures logicielles complexes
								</li>
								<li>
									Développement de chaînes de typage/interprétation, analyse
									statique de programmes et conception d'algorithmes pour
									graphes et applications Web/Mobile
								</li>
							</ul>
						</div>
					</div>
					<div class="timeline-item">
						<span class="period">2020 – 2024</span>
						<div class="timeline-body">
							<strong class="tl-role">Licence Informatique</strong>
							<span class="tl-org">Sorbonne Université</span>
							<ul class="tl-list">
								<li>
									Algorithmique, OS, réseaux, bases de données, programmation
									fonctionnelle et OO
								</li>
								<li>
									Nombreux projets collaboratifs : C, Java, OCaml, Python,
									TypeScript
								</li>
							</ul>
						</div>
					</div>
				</div>
			</section>

			<!-- ── EXPÉRIENCES ── -->
			<section id="experiences" class="section">
				<h2 class="section-title">Expériences</h2>
				<div class="timeline">
					<div class="timeline-item">
						<span class="period">2025 - 2026</span>
						<div class="timeline-body">
							<strong class="tl-role">Quality analyst</strong>
							<span class="tl-org">Hexaglobe</span>
							<ul class="tl-list">
								<li>
									Concevoir des systèmes de vérification et de contrôle de
									qualité pour chaque projet pour garantir la fiabilité et la
									cohérence des développements
								</li>
								<li>
									Automatisation des déploiements et des tests (CI/CD)
								</li>
							</ul>
						</div>
					</div>
					<div class="timeline-item">
						<span class="period">2023 - 2026</span>
						<div class="timeline-body">
							<strong class="tl-role">Responsable Technique</strong>
							<span class="tl-org">Association Play Sorbonne Université</span>
							<ul class="tl-list">
								<li>
									Infrastructure virtualisée : serveurs Docker, orchestration
									CI/CD, Google Workspace
								</li>
								<li>
									Site vitrine : <strong>9 000 visiteurs uniques</strong> en 2025,
									SEO on-page, analytics
								</li>
								<li>
									Web App mobile local-first pour suivi de quêtes : auth
									sécurisée, back-end optimisé haute charge
								</li>
							</ul>
						</div>
					</div>
					<div class="timeline-item">
						<span class="period">2024 - 2025</span>
						<div class="timeline-body">
							<strong class="tl-role">Président</strong>
							<span class="tl-org">Association Play Sorbonne Université</span>
							<ul class="tl-list">
								<li>
									Coordination de la stratégie globale, supervision des projets
								</li>
								<li>
									Management d'une équipe de <strong>100+ bénévoles</strong>
								</li>
								<li>
									Événement culturel accueillant <strong
										>10 000+ visiteurs</strong
									>
								</li>
							</ul>
						</div>
					</div>
					<div class="timeline-item">
						<span class="period">2021 - 2025</span>
						<div class="timeline-body">
							<strong class="tl-role">Employé Polyvalent</strong>
							<span class="tl-org">Lidl France, Asnières-sur-Seine</span>
							<ul class="tl-list">
								<li>
									Supervision des caisses, gestion des stocks, traitement des
									réclamations
								</li>
							</ul>
						</div>
					</div>
				</div>
			</section>

			<!-- ── COMPÉTENCES ── -->
			<section id="competences" class="section">
				<h2 class="section-title">Compétences</h2>
				<div class="skills-grid">
					<div class="skill-group">
						<h3 class="skill-label">Langues</h3>
						<div class="tags">
							{
								["Français (Natif)", "Anglais (Pro)", "Arabe (Conv)"].map(
									(t) => <span class="tag">{t}</span>,
								)
							}
						</div>
					</div>
				</div>
			</section>
		</main>

		<!-- ── FOOTER / CONTACT ── -->
		<footer id="contact" class="footer">
			<div class="container footer-inner">
				<p>
					<strong>Réda Boudrouss</strong> &mdash; Paris, France
				</p>
				<p>
					<a href="mailto:contact@rboud.com">contact@rboud.com</a>
					&nbsp;&middot;&nbsp;
					<a href="https://linkedin.com/in/rboudrouss" target="_blank"
						>LinkedIn</a
					>
					&nbsp;&middot;&nbsp;
					<a href="https://github.com/rboudrouss" target="_blank">GitHub</a>
				</p>
			</div>
		</footer>
	</div>
</BaseLayout>

<style>
	/* ── Layout ── */
	.page {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}
	.container {
		width: 100%;
		max-width: var(--container);
		margin-inline: auto;
		padding-inline: 1.5rem;
	}

	/* ── Nav ── */
	.topnav {
		position: sticky;
		top: 0;
		z-index: 10;
		background: rgba(249, 248, 245, 0.88);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border);
	}
	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 3.5rem;
	}
	.nav-name {
		font-weight: 600;
		font-size: 0.95rem;
		color: var(--text);
		letter-spacing: 0.02em;
	}
	.nav-links {
		display: flex;
		gap: 1.75rem;
		list-style: none;
	}
	.nav-links a {
		color: var(--text-muted);
		font-size: 0.9rem;
		font-weight: 500;
		transition: color var(--transition);
	}
	.nav-links a:hover {
		color: var(--accent);
		opacity: 1;
	}
	.lang-switch {
		font-weight: 700;
		border: 1px solid var(--border);
		padding: 0.15rem 0.5rem;
		border-radius: 0.25rem;
	}

	/* ── Hero ── */
	.hero {
		display: flex;
		flex-direction: column-reverse;
		gap: 2rem;
		padding-top: 4rem;
		padding-bottom: 4rem;
	}
	.hero-text {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.hero-text h1 {
		font-size: clamp(2.2rem, 5vw, 3.2rem);
		font-weight: 700;
	}
	.hero-title {
		font-size: 1.1rem;
		color: var(--accent);
		font-weight: 600;
	}
	.hero-institution {
		font-size: 0.9rem;
		color: var(--text-muted);
	}
	.hero-bio {
		max-width: 55ch;
		color: var(--text);
		line-height: 1.75;
		margin-top: 0.5rem;
	}
	.hero-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 0.75rem;
	}

	.btn {
		display: inline-block;
		padding: 0.45rem 1rem;
		border-radius: 0.375rem;
		font-size: 0.875rem;
		font-weight: 500;
		background: var(--accent);
		color: #fff;
		transition: background var(--transition);
	}
	.btn:hover {
		background: #1f5c42;
		opacity: 1;
	}
	.btn-ghost {
		background: var(--surface);
		color: var(--text);
		border: 1px solid var(--border);
	}
	.btn-ghost:hover {
		background: var(--accent-subtle);
		opacity: 1;
	}

	.hero-photo {
		display: flex;
		justify-content: center;
	}
	.avatar {
		width: 7rem;
		height: 7rem;
		background: var(--accent-subtle);
		color: var(--accent);
		font-family: var(--font-serif);
		font-size: 1.75rem;
		font-weight: 700;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 640px) {
		.hero {
			flex-direction: row;
			align-items: flex-start;
		}
		.hero-text {
			flex: 1;
		}
		.hero-photo {
			flex-shrink: 0;
			padding-top: 0.5rem;
		}
		.avatar {
			width: 9rem;
			height: 9rem;
			font-size: 2.25rem;
		}
	}

	/* ── Main sections ── */
	.main-content {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
		padding-bottom: 5rem;
	}
	.section {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	.section p {
		color: var(--text);
		max-width: 65ch;
	}
	.section-title {
		font-size: 1.35rem;
		font-weight: 700;
		padding-bottom: 0.5rem;
		border-bottom: 2px solid var(--accent-light);
		color: var(--text);
	}

	/* Timeline */
	.timeline {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.timeline-item {
		display: flex;
		gap: 1.25rem;
		align-items: flex-start;
	}
	.period {
		color: var(--text-muted);
		font-size: 0.8rem;
		font-weight: 600;
		min-width: 6rem;
		padding-top: 0.2rem;
		flex-shrink: 0;
	}
	.timeline-body {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.tl-role {
		font-size: 1rem;
		color: var(--text);
	}
	.tl-org {
		font-size: 0.85rem;
		color: var(--accent);
		font-weight: 500;
	}
	.tl-list {
		list-style: none;
		margin-top: 0.4rem;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}
	.tl-list li {
		font-size: 0.875rem;
		color: var(--text-muted);
		padding-left: 1rem;
		position: relative;
	}
	.tl-list li::before {
		content: "–";
		position: absolute;
		left: 0;
		color: var(--accent-light);
	}

	/* Skills */
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.5rem;
	}
	.skill-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.skill-label {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--text-muted);
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}
	.tag {
		font-size: 0.8rem;
		padding: 0.25rem 0.6rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 0.25rem;
		color: var(--text);
	}

	/* ── Footer ── */
	.footer {
		background: var(--surface);
		border-top: 1px solid var(--border);
	}
	.footer-inner {
		padding-block: 2rem;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}
	.footer p {
		font-size: 0.875rem;
		color: var(--text-muted);
	}
	.footer a {
		color: var(--link);
	}
</style>
