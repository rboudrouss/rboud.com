---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
---

<BaseLayout lang="en">
	<div class="page">
		<!-- ── NAV ── -->
		<nav class="topnav">
			<div class="container nav-inner">
				<span class="nav-name"></span>
				<ul class="nav-links">
					<li><a href="#education">Education</a></li>
					<li><a href="#experience">Experience</a></li>
					<li><a href="#projects">Projects</a></li>
					<li><a class="lang-switch" href="/fr/">FR</a></li>
				</ul>
			</div>
		</nav>

		<!-- ── HERO ── -->
		<header class="hero container">
			<div class="hero-text">
				<h1>Réda Boudrouss</h1>
				<p class="hero-title">
					M2 Student · Static Analysis &amp; WebAssembly
				</p>
				<p class="hero-institution">Sorbonne University</p>
				<p class="hero-bio">
					M2 STL student interested in <strong
						>static analysis of dynamic languages</strong
					> and the possibilities offered by <strong>WebAssembly</strong>.
					Currently working on porting the <strong
						><a href="https://mopsa.lip6.fr/" target="_blank">MOPSA</a></strong
					> analyzer to WebAssembly.
				</p>
				<div class="hero-links">
					<a class="btn" href="mailto:contact@rboud.com">✉ Email</a>
					<a
						class="btn btn-ghost"
						href="https://github.com/rboudrouss"
						target="_blank">GitHub</a
					>
					<a
						class="btn btn-ghost"
						href="https://linkedin.com/in/rboudrouss"
						target="_blank">LinkedIn</a
					>
					<a class="btn btn-ghost" href="/cv.pdf" target="_blank">CV (old)</a>
				</div>
			</div>
			<div class="hero-photo">
				<img class="avatar" src="/assets/photo.jpeg" alt="Reda Boudrouss" />
			</div>
		</header>

		<main class="container main-content">
			<!-- ── EDUCATION ── -->
			<section id="education" class="section">
				<h2 class="section-title">Education</h2>
				<div class="timeline">
					<div class="timeline-item">
						<span class="period">2024 – 2026</span>
						<div class="timeline-body">
							<strong class="tl-role">Master of Science in Software Technology</strong>
							<span class="tl-org">Sorbonne University</span>
							<ul class="tl-list">
								<li>
									Advanced algorithms, design and verification of safe software,
									concurrent, functional and distributed programming, and
									complex software architecture development
								</li>
								<li>
									Development of typing/interpretation pipelines, static program
									analysis, and algorithm design for graphs and Web/Mobile
									applications
								</li>
							</ul>
						</div>
					</div>
					<div class="timeline-item">
						<span class="period">2020 – 2024</span>
						<div class="timeline-body">
							<strong class="tl-role">Bachelor of Computer Science</strong>
							<span class="tl-org">Sorbonne University</span>
							<ul class="tl-list">
								<li>
									Algorithms, OS, networks, databases, functional and OO
									programming
								</li>
								<li>
									Many collaborative projects: C, Java, OCaml, Python,
									TypeScript
								</li>
							</ul>
						</div>
					</div>
				</div>
			</section>

			<!-- ── EXPERIENCE ── -->
			<section id="experience" class="section">
				<h2 class="section-title">Experience</h2>
				<div class="timeline">
					<div class="timeline-item">
						<span class="period">2025 – 2026</span>
						<div class="timeline-body">
							<strong class="tl-role">Quality Analyst</strong>
							<span class="tl-org">Hexaglobe</span>
							<ul class="tl-list">
								<li>
									Designing verification and quality control systems for each
									project to ensure reliability and consistency of developments
								</li>
								<li>Deployment and test automation (CI/CD)</li>
							</ul>
						</div>
					</div>
					<div class="timeline-item">
						<span class="period">2023 – 2026</span>
						<div class="timeline-body">
							<strong class="tl-role">Technical Lead</strong>
							<span class="tl-org">Play Sorbonne University Association</span>
							<ul class="tl-list">
								<li>
									Virtualized infrastructure: Docker servers, CI/CD
									orchestration, Google Workspace
								</li>
								<li>
									Showcase website: <strong>9,000 unique visitors</strong> in
									2025, on-page SEO, analytics
								</li>
								<li>
									Local-first mobile web app for quest tracking: secure auth,
									optimized high-load back-end
								</li>
							</ul>
						</div>
					</div>
					<div class="timeline-item">
						<span class="period">2024 – 2025</span>
						<div class="timeline-body">
							<strong class="tl-role">President</strong>
							<span class="tl-org">Play Sorbonne University Association</span>
							<ul class="tl-list">
								<li>Global strategy coordination, project supervision</li>
								<li>
									Managing a team of <strong>100+ volunteers</strong>
								</li>
								<li>
									Cultural event welcoming <strong>10,000+ visitors</strong>
								</li>
							</ul>
						</div>
					</div>
					<div class="timeline-item">
						<span class="period">2021 – 2025</span>
						<div class="timeline-body">
							<strong class="tl-role">General Employee</strong>
							<span class="tl-org">Lidl France, Asnières-sur-Seine</span>
							<ul class="tl-list">
								<li>
									Cash register supervision, stock management, complaint
									handling
								</li>
							</ul>
						</div>
					</div>
				</div>
			</section>

			<!-- ── PROJECTS ── -->
			<section id="projects" class="section">
				<h2 class="section-title">Projects</h2>
				<div class="projects-grid">
					{projects.map((p) => (
						<div class="project-card">
							<div class="project-header">
								<strong class="project-name">{p.name}</strong>
								<div class="project-links">
									{p.links.map((l) => (
										<a href={l.href} target="_blank" class="project-link">{l.label}</a>
									))}
								</div>
							</div>
							<p class="project-desc">{p.description.en}</p>
							<div class="tags">
								{p.tags.map((t) => <span class="tag">{t}</span>)}
							</div>
						</div>
					))}
				</div>
			</section>

			<!-- ── SKILLS ── -->
			<section id="skills" class="section">
				<h2 class="section-title">Skills</h2>
				<div class="skills-grid">
					<div class="skill-group">
						<h3 class="skill-label">Languages</h3>
						<div class="tags">
							{
								["French (Native)", "English (Professional)", "Arabic (Conversational)"].map(
									(t) => <span class="tag">{t}</span>,
								)
							}
						</div>
					</div>
				</div>
			</section>
		</main>

		<!-- ── FOOTER / CONTACT ── -->
		<footer id="contact" class="footer">
			<div class="container footer-inner">
				<p>
					<strong>Réda Boudrouss</strong> &mdash; Paris, France
				</p>
				<p>
					<a href="mailto:contact@rboud.com">contact@rboud.com</a>
					&nbsp;&middot;&nbsp;
					<a href="https://linkedin.com/in/rboudrouss" target="_blank"
						>LinkedIn</a
					>
					&nbsp;&middot;&nbsp;
					<a href="https://github.com/rboudrouss" target="_blank">GitHub</a>
				</p>
			</div>
		</footer>
	</div>
</BaseLayout>

<!-- Language detection: redirect French browser users to /fr/ unless they chose English manually -->
<script>
	if (!sessionStorage.getItem('lang-override')) {
		const lang = (navigator.language || '').toLowerCase();
		if (lang.startsWith('fr')) {
			window.location.replace('/fr/');
		}
	}
</script>

<style>
	/* ── Layout ── */
	.page {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}
	.container {
		width: 100%;
		max-width: var(--container);
		margin-inline: auto;
		padding-inline: 1.5rem;
	}

	/* ── Nav ── */
	.topnav {
		position: sticky;
		top: 0;
		z-index: 10;
		background: rgba(249, 248, 245, 0.88);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border);
	}
	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 3.5rem;
	}
	.nav-name {
		font-weight: 600;
		font-size: 0.95rem;
		color: var(--text);
		letter-spacing: 0.02em;
	}
	.nav-links {
		display: flex;
		gap: 1.75rem;
		list-style: none;
	}
	.nav-links a {
		color: var(--text-muted);
		font-size: 0.9rem;
		font-weight: 500;
		transition: color var(--transition);
	}
	.nav-links a:hover {
		color: var(--accent);
		opacity: 1;
	}
	.lang-switch {
		font-weight: 700;
		border: 1px solid var(--border);
		padding: 0.15rem 0.5rem;
		border-radius: 0.25rem;
	}

	/* ── Hero ── */
	.hero {
		display: flex;
		flex-direction: column-reverse;
		gap: 2rem;
		padding-top: 4rem;
		padding-bottom: 4rem;
	}
	.hero-text {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.hero-text h1 {
		font-size: clamp(2.2rem, 5vw, 3.2rem);
		font-weight: 700;
	}
	.hero-title {
		font-size: 1.1rem;
		color: var(--accent);
		font-weight: 600;
	}
	.hero-institution {
		font-size: 0.9rem;
		color: var(--text-muted);
	}
	.hero-bio {
		max-width: 55ch;
		color: var(--text);
		line-height: 1.75;
		margin-top: 0.5rem;
	}
	.hero-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 0.75rem;
	}

	.btn {
		display: inline-block;
		padding: 0.45rem 1rem;
		border-radius: 0.375rem;
		font-size: 0.875rem;
		font-weight: 500;
		background: var(--accent);
		color: #fff;
		transition: background var(--transition);
	}
	.btn:hover {
		background: #1f5c42;
		opacity: 1;
	}
	.btn-ghost {
		background: var(--surface);
		color: var(--text);
		border: 1px solid var(--border);
	}
	.btn-ghost:hover {
		background: var(--accent-subtle);
		opacity: 1;
	}

	.hero-photo {
		display: flex;
		justify-content: center;
	}
	.avatar {
		width: 7rem;
		height: 7rem;
		background: var(--accent-subtle);
		color: var(--accent);
		font-family: var(--font-serif);
		font-size: 1.75rem;
		font-weight: 700;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 640px) {
		.hero {
			flex-direction: row;
			align-items: flex-start;
		}
		.hero-text {
			flex: 1;
		}
		.hero-photo {
			flex-shrink: 0;
			padding-top: 0.5rem;
		}
		.avatar {
			width: 9rem;
			height: 9rem;
			font-size: 2.25rem;
		}
	}

	/* ── Main sections ── */
	.main-content {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
		padding-bottom: 5rem;
	}
	.section {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	.section p {
		color: var(--text);
		max-width: 65ch;
	}
	.section-title {
		font-size: 1.35rem;
		font-weight: 700;
		padding-bottom: 0.5rem;
		border-bottom: 2px solid var(--accent-light);
		color: var(--text);
	}

	/* Timeline */
	.timeline {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.timeline-item {
		display: flex;
		gap: 1.25rem;
		align-items: flex-start;
	}
	.period {
		color: var(--text-muted);
		font-size: 0.8rem;
		font-weight: 600;
		min-width: 6rem;
		padding-top: 0.2rem;
		flex-shrink: 0;
	}
	.timeline-body {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.tl-role {
		font-size: 1rem;
		color: var(--text);
	}
	.tl-org {
		font-size: 0.85rem;
		color: var(--accent);
		font-weight: 500;
	}
	.tl-list {
		list-style: none;
		margin-top: 0.4rem;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}
	.tl-list li {
		font-size: 0.875rem;
		color: var(--text-muted);
		padding-left: 1rem;
		position: relative;
	}
	.tl-list li::before {
		content: "–";
		position: absolute;
		left: 0;
		color: var(--accent-light);
	}

	/* Projects */
	.projects-grid {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	.project-card {
		border: 1px solid var(--border);
		border-radius: 0.5rem;
		padding: 1.25rem 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}
	.project-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.project-name {
		font-size: 1rem;
		color: var(--text);
	}
	.project-links {
		display: flex;
		gap: 0.5rem;
	}
	.project-link {
		font-size: 0.8rem;
		padding: 0.2rem 0.55rem;
		background: var(--accent-subtle);
		border: 1px solid var(--accent-light);
		border-radius: 0.25rem;
		color: var(--accent);
		font-weight: 500;
		transition: background var(--transition);
	}
	.project-link:hover {
		background: var(--accent-light);
		opacity: 1;
	}
	.project-desc {
		font-size: 0.875rem;
		color: var(--text-muted);
		line-height: 1.7;
		max-width: 70ch;
	}

	/* Skills */
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.5rem;
	}
	.skill-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.skill-label {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--text-muted);
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}
	.tag {
		font-size: 0.8rem;
		padding: 0.25rem 0.6rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 0.25rem;
		color: var(--text);
	}

	/* ── Footer ── */
	.footer {
		background: var(--surface);
		border-top: 1px solid var(--border);
	}
	.footer-inner {
		padding-block: 2rem;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}
	.footer p {
		font-size: 0.875rem;
		color: var(--text-muted);
	}
	.footer a {
		color: var(--link);
	}
</style>
